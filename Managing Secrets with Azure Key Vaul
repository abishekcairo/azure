# Base64 encode the plaintext first
base64 /root/SensitiveData.txt > /root/SensitiveData.b64

# Encrypt using your Key Vault RSA key
az keyvault key encrypt \
  --vault-name xfusion-29818 \
  --name xfusion-key \
  --algorithm RSA-OAEP \
  --value "$(cat /root/SensitiveData.b64)" \
  --query result -o tsv | base64 --decode > /root/EncryptedData.bin


#Decrypt the Ciphertext

ENC_VALUE=$(base64 -w0 /root/EncryptedData.bin)

az keyvault key decrypt \
  --vault-name xfusion-29818 \
  --name xfusion-key \
  --algorithm RSA-OAEP \
  --value "$ENC_VALUE" \
  --query result -o tsv > /root/DecryptedData.b64


#Restore the Original File
base64 --decode /root/DecryptedData.b64 > /root/DecryptedData.txt
